# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority

# Firebase Admin SDK Configuration (JSON string)
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id","private_key_id":"key-id","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@project.iam.gserviceaccount.com","client_id":"client-id","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# Firebase Client Config (for public/browser use)
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc...

# ImageKit Configuration (for image uploads)
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your_public_key
IMAGEKIT_PRIVATE_KEY=your_private_key
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id/

# Email Configuration
EMAIL_SERVICE_PROVIDER=resend  # or sendgrid, mailgun, etc
EMAIL_API_KEY=your_email_api_key

# Admin Configuration
ADMIN_EMAIL=admin@brandstored.com
NEXT_PUBLIC_ADMIN_EMAIL=admin@brandstored.com

# Application URLs
NEXT_PUBLIC_BASE_URL=http://localhost:3001

# Store Configuration
NEXT_PUBLIC_CURRENCY_SYMBOL=AED
NEXT_PUBLIC_COUNTRY_CODE=AE

# Optional: Razorpay Configuration
RAZORPAY_API_KEY=your_razorpay_key
RAZORPAY_API_SECRET=your_razorpay_secret

# Optional: Analytics / Tracking
NEXT_PUBLIC_GA_ID=UA-...
